{
  "name": "omnifin-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c auto \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m omnifin.cli.main serve --db ../data/omnifin.db --reload",
    "dev:frontend": "npm --prefix frontend run dev",
    "test:backend": "cd backend && python -m pytest",
    "install:backend": "python -m pip install -e backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
